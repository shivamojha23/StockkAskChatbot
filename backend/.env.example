# ============================================================
# StockkBot Environment Configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# --- OpenAI (Supports comma-separated keys for rate-limit failover/rotation) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Groq (Supports comma-separated keys for rate-limit failover/rotation) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Pinecone ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=stockkask-faq
PINECONE_ENVIRONMENT=us-east-1   # e.g., us-east-1, gcp-starter

# --- Qdrant (alternative to Pinecone) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=stockkask-faq

# --- App Config ---
APP_ENV=development              # development | production
ALLOWED_ORIGINS=https://stockk.trade,http://localhost:3000
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=20        # Requests per IP per minute
RATE_LIMIT_PER_DAY=500          # Requests per IP per day

# --- RAG Config ---
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
TOP_K_RESULTS=5                 # Number of context chunks to retrieve
MAX_CONTEXT_TOKENS=2000         # Max tokens for injected context
